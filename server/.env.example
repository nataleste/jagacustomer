DAYTONA_API_KEY=
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_ZONE=

# TokenRouter (OpenAI-compatible router) — optional; enables the Kimi plain-language
# summary on every real verdict. The code accepts either name in each pair below.
TOKENROUTER_API_KEY=
TOKENROUTER_BASE_URL=https://api.tokenrouter.com/v1   # alias accepted: TOKEN_ROUTER_API
TOKENROUTER_MODEL=moonshotai/kimi-k2.6                 # alias accepted: KIMI_MODEL
# Use kimi-k2.6: llm.py disables thinking for a fast, deterministic one-liner.
# Avoid kimi-k2.7-code — it forces reasoning on and returns empty answers here.
MINIMAX_M3_MODEL=minimax-m3                            # optional fallback explainer

# Twilio live-call intake — optional
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_PHONE_NUMBER=
PUBLIC_BASE_URL=
